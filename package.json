{
  "name": "talentdash",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "prisma migrate dev && prisma generate && prisma db seed && node scripts/prisma-startup-check.mjs && next dev",
    "build": "prisma generate && next build",
    "start": "prisma migrate deploy && prisma generate && prisma db seed && node scripts/prisma-startup-check.mjs && next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:check": "node scripts/prisma-startup-check.mjs",
    "db:init": "prisma migrate deploy && prisma generate && prisma db seed && node scripts/prisma-startup-check.mjs",
    "db:setup": "tsx prisma/setup-db.ts",
    "seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "next": "^15.3.3",
    "prisma": "^6.9.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215"
}
